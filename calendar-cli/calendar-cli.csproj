<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>calendar</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>CalendarCli</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Packaging configuration for self-contained, single-file executable -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Apis.Calendar.v3" Version="1.74.0.4154" />
  </ItemGroup>

  <Target Name="PublishOnBuild" AfterTargets="Build" Condition="'$(PublishInProgress)' != 'true'">
    <MSBuild Projects="$(MSBuildProjectFullPath)" Targets="Publish" Properties="Configuration=$(Configuration);PublishInProgress=true" />
  </Target>

  <Target Name="CopyPublishedExecutable" AfterTargets="Publish">
    <Copy SourceFiles="$(PublishDir)$(AssemblyName).exe" DestinationFolder="C:\Users\yuvaraj.nagarajan\" />
  </Target>

</Project>
